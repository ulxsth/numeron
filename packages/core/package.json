{
  "name": "@numeron/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "lint": "tsc -p tsconfig.build.json --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "~5.7.3",
    "vitest": "^3.0.5"
  }
}
